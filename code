from __future__ import annotations
import json
from pathlib import Path
from typing import Any, Dict, List
import numpy as np
import pandas as pd

from app.utils import ensure_1d_numeric
from config import SUPPORTED_SIGNAL_EXTENSIONS

def load_signal_file(path: str | Path) -> np.ndarray:
    path = Path(path)
    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")
    if path.suffix.lower() not in SUPPORTED_SIGNAL_EXTENSIONS:
        raise ValueError(f"Unsupported signal format: {path.suffix}")

    if path.suffix.lower() == ".npy":
        data = np.load(path)
        return ensure_1d_numeric(data)

    if path.suffix.lower() == ".json":
        payload = json.loads(path.read_text(encoding="utf-8"))
        if "signal" not in payload:
            raise ValueError("JSON must contain a 'signal' field.")
        return ensure_1d_numeric(payload["signal"])

    df = pd.read_csv(path)
    if "signal" in df.columns:
        return ensure_1d_numeric(df["signal"].to_numpy())

    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    if not numeric_cols:
        raise ValueError("CSV does not contain numeric columns.")
    return ensure_1d_numeric(df[numeric_cols[0]].to_numpy())

def load_baseline_dataset(index_csv: str | Path) -> pd.DataFrame:
    path = Path(index_csv)
    if not path.exists():
        raise FileNotFoundError(f"Dataset index not found: {path}")
    df = pd.read_csv(path)
    required = {"record_id", "signal_path"}
    missing = required - set(df.columns)
    if missing:
        raise ValueError(f"Dataset CSV is missing required columns: {sorted(missing)}")
    return df

def dataframe_to_records(df: pd.DataFrame) -> List[Dict[str, Any]]:
    return df.to_dict(orient="records")
