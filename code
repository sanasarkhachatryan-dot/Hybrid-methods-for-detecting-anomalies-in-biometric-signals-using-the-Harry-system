from __future__ import annotations
from pathlib import Path
from typing import Iterable
import numpy as np

def ensure_1d_numeric(array_like: Iterable) -> np.ndarray:
    arr = np.asarray(array_like, dtype=float).squeeze()
    if arr.ndim != 1:
        raise ValueError("Signal must be one-dimensional.")
    if arr.size < 32:
        raise ValueError("Signal is too short for analysis.")
    if not np.isfinite(arr).all():
        raise ValueError("Signal contains NaN or infinite values.")
    return arr

def safe_str(value) -> str:
    if value is None:
        return "unknown"
    text = str(value).strip()
    return text if text else "unknown"

def make_output_path(base_dir: Path, stem: str, suffix: str) -> Path:
    base_dir.mkdir(parents=True, exist_ok=True)
    candidate = base_dir / f"{stem}{suffix}"
    idx = 1
    while candidate.exists():
        candidate = base_dir / f"{stem}_{idx}{suffix}"
        idx += 1
    return candidate
''',

